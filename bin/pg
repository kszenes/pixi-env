#!/usr/bin/env bash
set -euo pipefail

PG_VERSION="0.1.0"
PG_HOME_DEFAULT="${HOME}/.pixi-global-envs"
PG_HOME="${PG_HOME:-${PIXIGLOBAL_HOME:-$PG_HOME_DEFAULT}}"

usage() {
  cat <<'EOF'
pg - pixi global environments

Usage:
  pg create -n <name> [package ...]  Create a global pixi environment
  pg add [-n <name>] <package ...>   Add packages to an environment (or active env)
  pg remove -n <name>                Delete an environment
  pg list                            List environments
  pg path [-n <name>]                Print global env root or environment path
  pg activate -n <name>              Activate an environment (after shell init)
  pg deactivate                      Deactivate the active environment
  pg run -n <name> -- <command>      Run a command in an environment
  pg shell-init                      Print shell integration for bash/zsh
  pg help                            Show this help

Environment variables:
  PG_HOME                            Directory where environments are stored
                                     (default: ~/.pixi-global-envs)

Install shell integration by adding this to ~/.bashrc or ~/.zshrc:
  eval "$(pg shell-init)"
EOF
}

err() { echo "pg: $*" >&2; }
die() { err "$*"; exit 1; }
need_pixi() { command -v pixi >/dev/null 2>&1 || die "pixi not found in PATH"; }

valid_name() {
  [[ "${1:-}" =~ ^[A-Za-z0-9._-]+$ ]] && [[ "$1" != "." ]] && [[ "$1" != ".." ]]
}

env_dir() {
  local name="$1"
  valid_name "$name" || die "invalid environment name '$name' (use letters, digits, '.', '_' or '-')"
  printf '%s/%s\n' "$PG_HOME" "$name"
}

manifest_for() { printf '%s/pixi.toml\n' "$(env_dir "$1")"; }

env_prefix_for_dir() {
  local dir="$1"
  printf '%s/.pixi/envs/default\n' "$dir"
}

ensure_env_exists() {
  local name="$1" dir
  dir="$(env_dir "$name")"
  [[ -f "$dir/pixi.toml" ]] || die "environment '$name' does not exist"
}

PARSED_NAME=""
PARSED_ARGS=()
parse_name_flag() {
  PARSED_NAME=""
  PARSED_ARGS=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n|--name)
        shift
        [[ $# -gt 0 ]] || die "-n/--name requires an environment name"
        PARSED_NAME="$1"
        shift
        ;;
      --)
        PARSED_ARGS+=("--")
        shift
        PARSED_ARGS+=("$@")
        break
        ;;
      *)
        PARSED_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

cmd_create() {
  parse_name_flag "$@"
  set -- ${PARSED_ARGS[@]+"${PARSED_ARGS[@]}"}
  [[ -n "$PARSED_NAME" ]] || die "usage: pg create -n <name> [package ...]"
  local name="$PARSED_NAME"
  need_pixi
  local dir
  dir="$(env_dir "$name")"
  [[ ! -e "$dir" ]] || die "environment '$name' already exists: $dir"
  mkdir -p "$PG_HOME"
  pixi init "$dir"
  if [[ $# -gt 0 ]]; then
    pixi add --manifest-path "$dir/pixi.toml" "$@"
  else
    pixi install --manifest-path "$dir/pixi.toml"
  fi
  echo "Created '$name' at $dir"
}

cmd_add() {
  parse_name_flag "$@"
  set -- ${PARSED_ARGS[@]+"${PARSED_ARGS[@]}"}
  [[ $# -ge 1 ]] || die "usage: pg add [-n <name>] <package ...>"
  need_pixi
  local name
  if [[ -n "$PARSED_NAME" ]]; then
    name="$PARSED_NAME"
  elif [[ -n "${PG_ACTIVE_ENV:-}" ]]; then
    name="$PG_ACTIVE_ENV"
  else
    die "usage: pg add [-n <name>] <package ...> (or activate an env first: pg activate -n <name>)"
  fi
  ensure_env_exists "$name"
  pixi add --manifest-path "$(manifest_for "$name")" "$@"
}

cmd_remove() {
  parse_name_flag "$@"
  set -- ${PARSED_ARGS[@]+"${PARSED_ARGS[@]}"}
  [[ -n "$PARSED_NAME" && $# -eq 0 ]] || die "usage: pg remove -n <name>"
  local name="$PARSED_NAME"
  local dir
  ensure_env_exists "$name"
  dir="$(env_dir "$name")"
  rm -rf -- "$dir"
  echo "Removed '$name'"
}

cmd_list() {
  mkdir -p "$PG_HOME"
  local found=0 dir name prefix marker
  for dir in "$PG_HOME"/*; do
    [[ -d "$dir" && -f "$dir/pixi.toml" ]] || continue
    found=1
    name="$(basename "$dir")"
    prefix="$(env_prefix_for_dir "$dir")"
    marker=" "
    [[ "${PG_ACTIVE_ENV:-}" == "$name" ]] && marker="*"
    if [[ -d "$prefix" ]]; then
      printf '%s %-24s %s\n' "$marker" "$name" "$dir"
    else
      printf '%s %-24s %s (not installed)\n' "$marker" "$name" "$dir"
    fi
  done
  [[ $found -eq 1 ]] || echo "No environments in $PG_HOME"
}

cmd_path() {
  parse_name_flag "$@"
  set -- ${PARSED_ARGS[@]+"${PARSED_ARGS[@]}"}
  if [[ -n "$PARSED_NAME" ]]; then
    [[ $# -eq 0 ]] || die "usage: pg path [-n <name>]"
    env_dir "$PARSED_NAME"
  elif [[ $# -eq 0 ]]; then
    printf '%s\n' "$PG_HOME"
  else
    die "usage: pg path [-n <name>]"
  fi
}

emit_activate() {
  parse_name_flag "$@"
  set -- ${PARSED_ARGS[@]+"${PARSED_ARGS[@]}"}
  [[ -n "$PARSED_NAME" && $# -eq 0 ]] || die "usage: pg activate -n <name>"
  local name="$PARSED_NAME"
  need_pixi
  local dir prefix
  ensure_env_exists "$name"
  dir="$(env_dir "$name")"
  pixi install --manifest-path "$dir/pixi.toml" >/dev/null
  prefix="$(env_prefix_for_dir "$dir")"
  [[ -d "$prefix" ]] || die "pixi environment prefix not found: $prefix"
  mkdir -p "$prefix/bin"
  cat <<EOF
if [ -z "\${PG_ACTIVE_ENV+x}" ]; then
  export PG_OLD_PATH="\${PATH}"

  if [ -n "\${CONDA_PREFIX+x}" ]; then export PG_OLD_CONDA_PREFIX="\${CONDA_PREFIX}"; export PG_OLD_CONDA_PREFIX_SET=1; else unset PG_OLD_CONDA_PREFIX; export PG_OLD_CONDA_PREFIX_SET=0; fi
  if [ -n "\${CONDA_DEFAULT_ENV+x}" ]; then export PG_OLD_CONDA_DEFAULT_ENV="\${CONDA_DEFAULT_ENV}"; export PG_OLD_CONDA_DEFAULT_ENV_SET=1; else unset PG_OLD_CONDA_DEFAULT_ENV; export PG_OLD_CONDA_DEFAULT_ENV_SET=0; fi
  if [ -n "\${CONDA_PROMPT_MODIFIER+x}" ]; then export PG_OLD_CONDA_PROMPT_MODIFIER="\${CONDA_PROMPT_MODIFIER}"; export PG_OLD_CONDA_PROMPT_MODIFIER_SET=1; else unset PG_OLD_CONDA_PROMPT_MODIFIER; export PG_OLD_CONDA_PROMPT_MODIFIER_SET=0; fi
  if [ -n "\${CONDA_SHLVL+x}" ]; then export PG_OLD_CONDA_SHLVL="\${CONDA_SHLVL}"; export PG_OLD_CONDA_SHLVL_SET=1; else unset PG_OLD_CONDA_SHLVL; export PG_OLD_CONDA_SHLVL_SET=0; fi
fi
export PG_ACTIVE_ENV="$name"
export PG_ACTIVE_ENV_DIR="$dir"
export PG_ACTIVE_PREFIX="$prefix"
export PATH="$prefix/bin:\${PG_OLD_PATH:-\$PATH}"
export CONDA_PREFIX="$prefix"
export CONDA_DEFAULT_ENV="$name"
export CONDA_PROMPT_MODIFIER="($name) "
export CONDA_SHLVL="\$((\${PG_OLD_CONDA_SHLVL:-0} + 1))"
hash -r 2>/dev/null || true
rehash 2>/dev/null || true
EOF
}

emit_deactivate() {
  cat <<'EOF'
if [ -n "${PG_ACTIVE_ENV+x}" ]; then
  if [ -n "${PG_OLD_PATH+x}" ]; then
    export PATH="${PG_OLD_PATH}"
    unset PG_OLD_PATH
  fi

  if [ "${PG_OLD_CONDA_PREFIX_SET:-0}" = 1 ]; then export CONDA_PREFIX="${PG_OLD_CONDA_PREFIX}"; else unset CONDA_PREFIX; fi
  if [ "${PG_OLD_CONDA_DEFAULT_ENV_SET:-0}" = 1 ]; then export CONDA_DEFAULT_ENV="${PG_OLD_CONDA_DEFAULT_ENV}"; else unset CONDA_DEFAULT_ENV; fi
  if [ "${PG_OLD_CONDA_PROMPT_MODIFIER_SET:-0}" = 1 ]; then export CONDA_PROMPT_MODIFIER="${PG_OLD_CONDA_PROMPT_MODIFIER}"; else unset CONDA_PROMPT_MODIFIER; fi
  if [ "${PG_OLD_CONDA_SHLVL_SET:-0}" = 1 ]; then export CONDA_SHLVL="${PG_OLD_CONDA_SHLVL}"; else unset CONDA_SHLVL; fi

  unset PG_ACTIVE_ENV PG_ACTIVE_ENV_DIR PG_ACTIVE_PREFIX
  unset PG_OLD_CONDA_PREFIX PG_OLD_CONDA_PREFIX_SET
  unset PG_OLD_CONDA_DEFAULT_ENV PG_OLD_CONDA_DEFAULT_ENV_SET
  unset PG_OLD_CONDA_PROMPT_MODIFIER PG_OLD_CONDA_PROMPT_MODIFIER_SET
  unset PG_OLD_CONDA_SHLVL PG_OLD_CONDA_SHLVL_SET
  hash -r 2>/dev/null || true
  rehash 2>/dev/null || true
fi
EOF
}

cmd_activate_standalone() {
  parse_name_flag "$@"
  set -- ${PARSED_ARGS[@]+"${PARSED_ARGS[@]}"}
  [[ -n "$PARSED_NAME" && $# -eq 0 ]] || die "usage: pg activate -n <name>"
  local name="$PARSED_NAME"
  cat >&2 <<EOF
pg activate must be evaluated by your shell.

One-time setup for bash/zsh:
  eval "\$(pg shell-init)"

Then run:
  pg activate -n $name
EOF
}

cmd_deactivate_standalone() {
  cat >&2 <<'EOF'
pg deactivate must be evaluated by your shell.

One-time setup for bash/zsh:
  eval "$(pg shell-init)"
EOF
}

cmd_run() {
  parse_name_flag "$@"
  set -- ${PARSED_ARGS[@]+"${PARSED_ARGS[@]}"}
  need_pixi
  [[ -n "$PARSED_NAME" ]] || die "usage: pg run -n <name> -- <command> [args]"
  local name="$PARSED_NAME"
  [[ $# -ge 2 && "$1" == "--" ]] || die "usage: pg run -n <name> -- <command> [args]"
  shift
  ensure_env_exists "$name"
  pixi run --manifest-path "$(manifest_for "$name")" "$@"
}

cmd_shell_init() {
  local pg_bin
  if [[ "$0" == */* ]]; then
    pg_bin="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
  else
    pg_bin="$(command -v "$0")"
  fi
  cat <<EOF
pg() {
  local _pg_cmd="\${1:-}"
  if [ "\$#" -gt 0 ]; then shift; fi
  case "\$_pg_cmd" in
    activate)
      eval "\$("$pg_bin" __activate "\$@")"
      ;;
    deactivate)
      eval "\$("$pg_bin" __deactivate)"
      ;;
    "")
      "$pg_bin"
      ;;
    *)
      "$pg_bin" "\$_pg_cmd" "\$@"
      ;;
  esac
}
EOF
}

main() {
  local cmd="${1:-help}"
  if [[ $# -gt 0 ]]; then shift; fi
  case "$cmd" in
    create) cmd_create "$@" ;;
    add) cmd_add "$@" ;;
    remove) cmd_remove "$@" ;;
    list) cmd_list "$@" ;;
    path) cmd_path "$@" ;;
    activate) cmd_activate_standalone "$@" ;;
    deactivate) cmd_deactivate_standalone "$@" ;;
    run) cmd_run "$@" ;;
    shell-init) cmd_shell_init "$@" ;;
    __activate) emit_activate "$@" ;;
    __deactivate) emit_deactivate "$@" ;;
    help|-h|--help) usage ;;
    version|--version) echo "pg $PG_VERSION" ;;
    *) die "unknown command '$cmd' (try: pg help)" ;;
  esac
}

main "$@"
